@model PaymentViewModel
@{ ViewData["Title"] = "Edit Payment"; }
<div class="d-flex align-items-center gap-2 mb-3"><i class="bi bi-pencil-fill" style="font-size:1.3rem"></i><h3 style="margin:0">Edit Payment</h3></div><hr />
<div class="row"><div class="col-md-6"><div class="card"><div class="card-body">
<form asp-action="Edit">
<div asp-validation-summary="ModelOnly" class="text-danger"></div>
<input type="hidden" asp-for="Id" />
<div class="mb-3"><label asp-for="OrderId" class="form-label"></label><select asp-for="OrderId" asp-items="@(ViewBag.OrderId as SelectList)" class="form-select"><option value="">-- Select Order --</option></select><span asp-validation-for="OrderId" class="text-danger"></span></div>
<div class="mb-3"><label asp-for="PaymentMethodId" class="form-label"></label><select asp-for="PaymentMethodId" asp-items="@(ViewBag.PaymentMethodId as SelectList)" class="form-select"><option value="">-- Select Method --</option></select><span asp-validation-for="PaymentMethodId" class="text-danger"></span></div>
<div class="mb-3"><label asp-for="Amount" class="form-label"></label><div class="input-group"><span class="input-group-text" style="border-radius:10px 0 0 10px">$</span><input asp-for="Amount" class="form-control" style="border-radius:0 10px 10px 0" /></div><span asp-validation-for="Amount" class="text-danger"></span></div>
<div class="mb-3"><label asp-for="TransactionId" class="form-label"></label><input asp-for="TransactionId" class="form-control" /><span asp-validation-for="TransactionId" class="text-danger"></span></div>
<div class="mb-3"><label asp-for="Status" class="form-label"></label><select asp-for="Status" class="form-select"><option value="Pending">Pending</option><option value="Completed">Completed</option><option value="Failed">Failed</option><option value="Refunded">Refunded</option></select><span asp-validation-for="Status" class="text-danger"></span></div>
<div class="mt-4 d-flex gap-2"><button type="submit" class="btn btn-primary"><i class="bi bi-save-fill"></i> Save</button><a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Back</a></div>
</form>
</div></div></div></div>
@section Scripts { @await Html.PartialAsync("_ValidationScriptsPartial") }
