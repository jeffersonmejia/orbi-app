@model PaymentViewModel
@{ ViewData["Title"] = "Payment Details"; }
<div class="d-flex align-items-center gap-2 mb-3"><i class="bi bi-eye-fill" style="font-size:1.3rem"></i><h3 style="margin:0">Payment Details</h3></div><hr />
<div class="card"><div class="card-body">
<dl class="row mb-0">
<dt class="col-sm-3">@Html.DisplayNameFor(m=>m.OrderInfo)</dt><dd class="col-sm-9">@Model.OrderInfo</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(m=>m.PaymentMethodName)</dt><dd class="col-sm-9">@Model.PaymentMethodName</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(m=>m.Amount)</dt><dd class="col-sm-9">@Model.Amount.ToString("C")</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(m=>m.TransactionId)</dt><dd class="col-sm-9">@(Model.TransactionId ?? "N/A")</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(m=>m.Status)</dt><dd class="col-sm-9">@Model.Status</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(m=>m.PaymentDate)</dt><dd class="col-sm-9">@Model.PaymentDate.ToString("g")</dd>
</dl>
</div><div class="card-footer">
<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning"><i class="bi bi-pencil-fill"></i> Edit</a>
<a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Back</a>
</div></div>
