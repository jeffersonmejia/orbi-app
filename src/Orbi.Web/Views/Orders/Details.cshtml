@model OrderViewModel

@{
    ViewData["Title"] = "Order Details";
}

<div class="d-flex align-items-center gap-2 mb-3">
    <i class="bi bi-eye-fill" style="font-size: 1.3rem;"></i>
    <h3 style="margin: 0;">Order Details</h3>
</div>
<hr />

<div class="row">
    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-header">Order Information</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">Order ID</dt>
                    <dd class="col-sm-7">@Model.Id</dd>

                    <dt class="col-sm-5">@Html.DisplayNameFor(m => m.CustomerName)</dt>
                    <dd class="col-sm-7">@Model.CustomerName</dd>

                    <dt class="col-sm-5">@Html.DisplayNameFor(m => m.StoreName)</dt>
                    <dd class="col-sm-7">@Model.StoreName</dd>

                    <dt class="col-sm-5">@Html.DisplayNameFor(m => m.DriverName)</dt>
                    <dd class="col-sm-7">@(Model.DriverName ?? "Not assigned")</dd>

                    <dt class="col-sm-5">@Html.DisplayNameFor(m => m.OrderStatusName)</dt>
                    <dd class="col-sm-7">
                        <span class="badge bg-@(Model.OrderStatusName switch
                        {
                            "Pending" => "warning",
                            "Confirmed" => "info",
                            "Preparing" => "primary",
                            "In Transit" => "secondary",
                            "Delivered" => "success",
                            "Cancelled" => "danger",
                            _ => "dark"
                        })">
                            @Model.OrderStatusName
                        </span>
                    </dd>

                    <dt class="col-sm-5">@Html.DisplayNameFor(m => m.TotalAmount)</dt>
                    <dd class="col-sm-7">@Model.TotalAmount.ToString("C")</dd>

                    <dt class="col-sm-5">@Html.DisplayNameFor(m => m.OrderDate)</dt>
                    <dd class="col-sm-7">@Model.OrderDate.ToString("g")</dd>

                    <dt class="col-sm-5">@Html.DisplayNameFor(m => m.DeliveryDate)</dt>
                    <dd class="col-sm-7">@(Model.DeliveryDate?.ToString("g") ?? "Pending")</dd>

                    <dt class="col-sm-5">@Html.DisplayNameFor(m => m.AddressLine)</dt>
                    <dd class="col-sm-7">@Model.AddressLine</dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-header">Order Items</div>
            <div class="card-body p-0">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th class="text-center">Qty</th>
                            <th class="text-end">Price</th>
                            <th class="text-end">Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@item.ProductName</td>
                                <td class="text-center">@item.Quantity</td>
                                <td class="text-end">@item.UnitPrice.ToString("C")</td>
                                <td class="text-end">@item.Subtotal.ToString("C")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="fw-bold">
                            <td colspan="3" class="text-end">Total:</td>
                            <td class="text-end">@Model.TotalAmount.ToString("C")</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="d-flex gap-2">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
        <i class="bi bi-pencil-fill"></i>
        Edit
    </a>
    <a asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i>
        Back
    </a>
</div>
