@model PaginatedList<OrderViewModel>

@{
    ViewData["Title"] = "Orders";
}

<div class="skeleton-container">
    <div class="skeleton-wrap">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
            <div class="skeleton skeleton-title" style="margin: 0;"></div>
            <div class="skeleton" style="width: 150px; height: 36px; border-radius: 999px;"></div>
        </div>
        <div class="skeleton skeleton-table" style="border-radius: var(--radius); padding: 0; overflow: hidden;">
            <div class="skeleton-th" style="height: 40px;"></div>
            <div class="skeleton-tr"></div>
            <div class="skeleton-tr"></div>
            <div class="skeleton-tr"></div>
            <div class="skeleton-tr"></div>
            <div class="skeleton-tr"></div>
        </div>
    </div>
    <div class="content-real">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h3 style="margin: 0;">
                <i class="bi bi-bag-fill" style="vertical-align: -4px; margin-right: 6px; font-size: 1.3rem;"></i>
                Orders
                <small class="text-muted" style="font-weight: 400; font-size: 0.85rem;">(@Model.TotalCount total)</small>
            </h3>
            <div class="d-flex gap-2 align-items-center">
                <form method="get" class="d-flex gap-2" id="search-form" style="margin: 0;">
                    <div class="input-group" style="max-width: 320px;">
                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                        <input type="text" name="searchTerm" class="form-control" placeholder="Search orders..."
                               value="@ViewBag.SearchTerm" />
                    </div>
                    <select name="searchField" class="form-select" style="max-width: 140px;">
                        <option value="customer" selected="@(ViewBag.SearchField == "customer" || ViewBag.SearchField == null)">Customer</option>
                        <option value="store" selected="@(ViewBag.SearchField == "store")">Store</option>
                        <option value="status" selected="@(ViewBag.SearchField == "status")">Status</option>
                    </select>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-search"></i></button>
                    @if (!string.IsNullOrEmpty(ViewBag.SearchTerm))
                    {
                        <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-x-lg"></i></a>
                    }
                </form>
                <a asp-action="Create" class="btn btn-success">
                    <i class="bi bi-plus-lg"></i>
                    Create New Order
                </a>
            </div>
        </div>

        <div class="card" style="padding: 0;">
            <div style="overflow-x: auto;">
                <table class="table">
                    <thead>
                        <tr>
                            <th style="width: 50px;">No.</th>
                            <th>Customer</th>
                            <th>Store</th>
                            <th>Total</th>
                            <th>Status</th>
                            <th>Updated at</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int rowNum = (Model.PageIndex - 1) * Model.PageSize + 1;
                        }
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@rowNum</td>
                                <td>@item.CustomerName</td>
                                <td>@item.StoreName</td>
                                <td>@item.TotalAmount.ToString("C")</td>
                                <td>
                                    <span class="badge bg-@(item.OrderStatusName switch
                                    {
                                        "Pending" => "warning",
                                        "Confirmed" => "info",
                                        "Preparing" => "primary",
                                        "In Transit" => "secondary",
                                        "Delivered" => "success",
                                        "Cancelled" => "danger",
                                        _ => "dark"
                                    })">
                                        @item.OrderStatusName
                                    </span>
                                </td>
                                <td>@item.OrderDate.ToRelativeTime()</td>
                                <td class="text-center">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info" title="Details">
                                        <i class="bi bi-eye-fill"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning" title="Edit">
                                        <i class="bi bi-pencil-fill"></i>
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline"
                                          onsubmit="return confirm('Are you sure you want to delete this order?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-danger" title="Delete">
                                            <i class="bi bi-trash-fill"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                            rowNum++;
                        }
                    </tbody>
                </table>
            </div>
        </div>
@await Html.PartialAsync("_Pagination", new PaginationViewModel(Model.PageIndex, Model.TotalPages, ViewBag.SearchField, ViewBag.SearchTerm))
    </div>
</div>

@if (!Model.Items.Any() && string.IsNullOrEmpty(ViewBag.SearchTerm))
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-bag" style="font-size: 2.5rem; margin-bottom: 0.5rem;"></i>
        <p>No orders found. Create your first order!</p>
    </div>
}
else if (!Model.Items.Any() && !string.IsNullOrEmpty(ViewBag.SearchTerm))
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-search" style="font-size: 2.5rem; margin-bottom: 0.5rem;"></i>
        <p>No orders match "<strong>@ViewBag.SearchTerm</strong>".</p>
    </div>
}
