@model IEnumerable<OrderViewModel>

@{
    ViewData["Title"] = "Orders";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3><i class="bi bi-cart-check"></i> Orders</h3>
    <a asp-action="Create" class="btn btn-success">
        <i class="bi bi-plus-lg"></i> Create New Order
    </a>
</div>

<div class="card p-0">
    <div class="table-responsive">
        <table class="table mb-0">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>@Html.DisplayNameFor(m => m.First().CustomerName)</th>
                    <th>@Html.DisplayNameFor(m => m.First().StoreName)</th>
                    <th>@Html.DisplayNameFor(m => m.First().TotalAmount)</th>
                    <th>@Html.DisplayNameFor(m => m.First().OrderStatusName)</th>
                    <th>@Html.DisplayNameFor(m => m.First().OrderDate)</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.CustomerName</td>
                        <td>@item.StoreName</td>
                        <td>@item.TotalAmount.ToString("C")</td>
                        <td>
                            <span class="badge bg-@(item.OrderStatusName switch
                            {
                                "Pending" => "warning",
                                "Confirmed" => "info",
                                "Preparing" => "primary",
                                "In Transit" => "secondary",
                                "Delivered" => "success",
                                "Cancelled" => "danger",
                                _ => "dark"
                            })">
                                @item.OrderStatusName
                            </span>
                        </td>
                        <td>@item.OrderDate.ToString("g")</td>
                        <td class="text-center">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info" title="Details">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning" title="Edit">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Are you sure you want to delete this order?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-danger" title="Delete">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-cart-check display-4"></i>
        <p class="mt-2">No orders found. Create your first order!</p>
    </div>
}
