@model PaginatedList<ProductViewModel>

@{
    ViewData["Title"] = "Products";
}

<div class="skeleton-container">
    <div class="skeleton-wrap">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
            <div class="skeleton skeleton-title" style="margin: 0;"></div>
            <div class="skeleton" style="width: 150px; height: 36px; border-radius: 999px;"></div>
        </div>
        <div class="skeleton skeleton-table" style="border-radius: var(--radius); padding: 0; overflow: hidden;">
            <div class="skeleton-th" style="height: 40px;"></div>
            <div class="skeleton-tr"></div>
            <div class="skeleton-tr"></div>
            <div class="skeleton-tr"></div>
            <div class="skeleton-tr"></div>
            <div class="skeleton-tr"></div>
        </div>
    </div>
    <div class="content-real">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h3>
                <i class="bi bi-box-seam-fill" style="vertical-align: -4px; margin-right: 6px; font-size: 1.3rem;"></i>
                Products
            </h3>
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-lg"></i>
                Create New Product
            </a>
        </div>

        <form method="get" class="d-flex gap-2 mb-3" id="search-form">
            <div class="input-group" style="max-width: 320px;">
                <span class="input-group-text"><i class="bi bi-search"></i></span>
                <input type="text" name="searchTerm" class="form-control" placeholder="Search products..."
                       value="@ViewBag.SearchTerm" />
            </div>
            <select name="searchField" class="form-select" style="max-width: 160px;">
                <option value="name" selected="@(ViewBag.SearchField == "name" || ViewBag.SearchField == null)">Name</option>
                <option value="store" selected="@(ViewBag.SearchField == "store")">Store</option>
            </select>
            <button type="submit" class="btn btn-primary"><i class="bi bi-search"></i></button>
            @if (!string.IsNullOrEmpty(ViewBag.SearchTerm))
            {
                <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-x-lg"></i></a>
            }
        </form>

        <div class="card" style="padding: 0;">
            <div style="overflow-x: auto;">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Store</th>
                            <th>Price</th>
                            <th>Stock</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@item.Name</td>
                                <td>@item.StoreName</td>
                                <td>@item.Price.ToString("C")</td>
                                <td>@item.Stock</td>
                                <td class="text-center">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info" title="Details">
                                        <i class="bi bi-eye-fill"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning" title="Edit">
                                        <i class="bi bi-pencil-fill"></i>
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline"
                                          onsubmit="return confirm('Are you sure you want to delete this product?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-danger" title="Delete">
                                            <i class="bi bi-trash-fill"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @if (Model.TotalPages > 1)
        {
            <nav class="mt-3 d-flex justify-content-center">
                <ul class="pagination">
                    <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                        <a class="page-link" asp-action="Index" asp-route-page="@(Model.PageIndex - 1)"
                           asp-route-searchField="@ViewBag.SearchField" asp-route-searchTerm="@ViewBag.SearchTerm">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                            <a class="page-link" asp-action="Index" asp-route-page="@i"
                               asp-route-searchField="@ViewBag.SearchField" asp-route-searchTerm="@ViewBag.SearchTerm">@i</a>
                        </li>
                    }
                    <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                        <a class="page-link" asp-action="Index" asp-route-page="@(Model.PageIndex + 1)"
                           asp-route-searchField="@ViewBag.SearchField" asp-route-searchTerm="@ViewBag.SearchTerm">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        }
    </div>
</div>

@if (!Model.Items.Any() && string.IsNullOrEmpty(ViewBag.SearchTerm))
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-box-seam" style="font-size: 2.5rem; margin-bottom: 0.5rem;"></i>
        <p>No products found. Create your first product!</p>
    </div>
}
else if (!Model.Items.Any() && !string.IsNullOrEmpty(ViewBag.SearchTerm))
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-search" style="font-size: 2.5rem; margin-bottom: 0.5rem;"></i>
        <p>No products match "<strong>@ViewBag.SearchTerm</strong>".</p>
    </div>
}
