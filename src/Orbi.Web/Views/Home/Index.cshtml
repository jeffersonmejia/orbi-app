@{
    ViewData["Title"] = "Home";
}

<div class="text-center py-5">
    <div class="display-1 text-primary mb-3">
        <i class="bi bi-globe2"></i>
    </div>
    <h1 class="display-4 fw-bold">Welcome to Orbi</h1>
    <p class="lead text-muted mb-4">
        Your unified multi-service delivery platform. Restaurants, pharmacies, and supermarkets — all in one orbit.
    </p>
    <div class="row justify-content-center g-4">
        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body text-center">
                    <i class="bi bi-shop display-6 text-primary"></i>
                    <h5 class="card-title mt-2">Products</h5>
                    <p class="card-text text-muted">Browse and manage products across all stores.</p>
                    <a asp-controller="Products" asp-action="Index" class="btn btn-primary">
                        <i class="bi bi-arrow-right"></i> Go to Products
                    </a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body text-center">
                    <i class="bi bi-cart-check display-6 text-success"></i>
                    <h5 class="card-title mt-2">Orders</h5>
                    <p class="card-text text-muted">Track and manage customer orders in real time.</p>
                    <a asp-controller="Orders" asp-action="Index" class="btn btn-success">
                        <i class="bi bi-arrow-right"></i> Go to Orders
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
