@model Orbi.Web.ViewModels.HomeDashboardViewModel
@using System.Globalization
@{
    ViewData["Title"] = "Home";
    var englishCulture = CultureInfo.GetCultureInfo("en-US");

    string ShortLabel(string value)
    {
        const int maxLength = 9;
        return value.Length <= maxLength ? value : value[..maxLength] + "...";
    }
}

<section class="home-dashboard">
    <div class="home-stack">
        <div class="home-total glass" aria-label="Total records" data-reveal>
            <i class="bi bi-database-fill"></i>
            <span>Total records</span>
            <strong data-total-records data-current-count="@Model.TotalRecords">@Model.TotalRecords.ToString("N0", englishCulture)</strong>
        </div>
        <div class="home-chart glass" data-reveal>
            @foreach (var item in Model.TableCounts)
            {
                var height = Model.MaxRecords == 0 ? 0 : Math.Max(8, (int)Math.Round(item.Count * 100.0 / Model.MaxRecords));
                <div class="home-chart__row" data-chart-row data-table-name="@item.TableName" style="--bar-height: @height%;">
                    <span class="home-chart__value" data-record-count data-current-count="@item.Count">@item.Count.ToString("N0", englishCulture)</span>
                    <div class="home-chart__track" aria-label="@item.TableName: @item.Count records">
                        <div class="home-chart__bar"></div>
                    </div>
                    <div class="home-chart__label">
                        <span class="home-chart__icon"><i class="bi @item.Icon"></i></span>
                        @if (item.ControllerName is not null)
                        {
                            <a asp-controller="@item.ControllerName" asp-action="Index" title="@item.TableName">@ShortLabel(item.TableName)</a>
                        }
                        else
                        {
                            <span title="@item.TableName">@ShortLabel(item.TableName)</span>
                        }
                    </div>
                </div>
            }
        </div>
        <footer class="home-footer">
            &copy; 2026 Orbi Platform &mdash; All rights reserved.
        </footer>
    </div>
</section>

<style>
    .home-dashboard {
        --home-ink: var(--purple-800);
        --home-ink-strong: var(--purple-900);
        --home-muted: var(--purple-600);
        --home-surface: rgba(255, 255, 255, 0.32);
        --home-surface-strong: rgba(255, 255, 255, 0.42);
        --home-border: rgba(255, 255, 255, 0.54);
        --home-fill: rgba(196, 181, 253, 0.62);
        color: var(--home-ink);
        display: grid;
        min-height: calc(100vh - 8.75rem);
        place-items: center;
    }

    .home-dashboard a,
    .home-dashboard span,
    .home-dashboard small,
    .home-dashboard strong {
        color: inherit;
    }

    .home-stack {
        align-items: center;
        display: flex !important;
        flex-direction: column;
        row-gap: 1.75rem !important;
        justify-items: center;
        width: 100%;
    }

    .home-stack > .home-total,
    .home-stack > .home-chart,
    .home-stack > .home-footer {
        margin: 0 !important;
    }

    .home-total {
        align-items: center;
        background: var(--glass-sheen), var(--home-surface-strong);
        background-blend-mode: screen, normal;
        backdrop-filter: blur(24px) saturate(200%) contrast(1.04);
        -webkit-backdrop-filter: blur(24px) saturate(200%) contrast(1.04);
        border: 0;
        border-radius: var(--radius);
        box-shadow: none;
        color: var(--home-ink-strong);
        display: inline-flex;
        font-size: 1.18rem;
        font-weight: 700;
        gap: 0.6rem;
        justify-content: center;
        line-height: 1;
        padding: 0.68rem 1.05rem;
        transition:
            background-color 0.35s ease,
            transform 0.35s cubic-bezier(0.22, 1, 0.36, 1),
            opacity 0.35s ease;
        white-space: nowrap;
    }

    .home-total.is-updating {
        opacity: 0.92;
        transform: translateY(-1px) scale(1.012);
    }

    .home-total i {
        color: var(--home-muted);
        font-size: 1.05rem;
    }

    .home-chart {
        background: var(--glass-sheen), var(--home-surface);
        background-blend-mode: screen, normal;
        backdrop-filter: blur(34px) saturate(210%) contrast(1.06);
        -webkit-backdrop-filter: blur(34px) saturate(210%) contrast(1.06);
        border: 0;
        border-radius: var(--radius);
        box-shadow: 0 10px 34px rgba(109, 40, 217, 0.06);
        display: grid;
        align-items: end;
        gap: 0.65rem;
        grid-template-columns: repeat(auto-fit, minmax(74px, 1fr));
        max-width: 1080px;
        padding: 0.82rem 1rem;
        width: 100%;
    }

    .home-chart__row {
        align-items: end;
        display: grid;
        gap: 0.34rem;
        grid-template-areas:
            "value"
            "track"
            "label";
        grid-template-rows: 0.9rem 98px 3.15rem;
        justify-items: center;
        min-width: 0;
    }

    .home-chart__row.is-updating .home-chart__icon,
    .home-chart__row.is-updating .home-chart__value {
        animation: home-soft-pop 0.42s cubic-bezier(0.22, 1, 0.36, 1) both;
    }

    .home-chart__row:nth-child(5n + 2) { --bar-fill: var(--purple-200); }
    .home-chart__row:nth-child(5n + 3) { --bar-fill: var(--purple-300); }
    .home-chart__row:nth-child(5n + 4) { --bar-fill: var(--purple-400); }
    .home-chart__row:nth-child(5n) { --bar-fill: #d8b4fe; }
    .home-chart__row:nth-child(5n + 1) { --bar-fill: #c4b5fd; }

    .home-chart__label {
        align-items: center;
        color: var(--home-ink);
        display: flex;
        flex-direction: column;
        font-size: 0.7rem;
        font-weight: 500;
        gap: 0.28rem;
        grid-area: label;
        line-height: 1.12;
        min-width: 0;
        text-align: center;
        width: 100%;
    }

    .home-chart__label a,
    .home-chart__label span {
        overflow-wrap: anywhere;
        max-width: 100%;
    }

    .home-chart__icon {
        align-items: center;
        background: rgba(237, 233, 254, 0.42);
        background-blend-mode: screen, normal;
        backdrop-filter: blur(10px) saturate(180%);
        -webkit-backdrop-filter: blur(10px) saturate(180%);
        border: 0;
        border-radius: 50%;
        color: var(--home-muted);
        display: inline-flex;
        flex: 0 0 24px;
        height: 24px;
        justify-content: center;
        width: 24px;
    }

    .home-chart__track {
        align-items: end;
        background: rgba(237, 233, 254, 0.42);
        border: 0;
        border-radius: var(--radius-pill);
        display: flex;
        grid-area: track;
        height: 98px;
        justify-content: center;
        overflow: hidden;
        position: relative;
        width: 38px;
    }

    .home-chart__bar {
        background: var(--bar-fill, var(--home-fill));
        border-radius: inherit;
        bottom: 0;
        left: 0;
        height: var(--bar-height);
        min-height: 0;
        position: absolute;
        transform-origin: bottom;
        animation: bar-rise 0.7s cubic-bezier(0.22, 1, 0.36, 1) both;
        transition:
            height 0.72s cubic-bezier(0.22, 1, 0.36, 1),
            filter 0.42s ease,
            opacity 0.42s ease;
        width: 100%;
    }

    .home-chart__row.is-updating .home-chart__bar {
        filter: saturate(1.16) brightness(1.04);
        opacity: 0.92;
    }

    .home-chart__value {
        color: var(--home-muted);
        font-size: 0.76rem;
        font-weight: 500;
        grid-area: value;
        line-height: 1;
        text-align: right;
    }

    .home-footer {
        color: var(--home-muted);
        font-size: 0.78rem;
        line-height: 1;
        padding-top: 0;
        text-align: center;
    }

    @@keyframes bar-rise {
        from {
            transform: scaleY(0);
        }
        to {
            transform: scaleY(1);
        }
    }

    @@keyframes home-soft-pop {
        0% {
            opacity: 0.72;
            transform: translateY(3px) scale(0.985);
        }
        100% {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    @@media (prefers-reduced-motion: reduce) {
        .home-total,
        .home-chart__bar {
            transition: none;
        }

        .home-chart__row.is-updating .home-chart__icon,
        .home-chart__row.is-updating .home-chart__value {
            animation: none;
        }
    }

    @@media (max-width: 720px) {
        .home-chart__row {
            grid-template-rows: 0.9rem 86px 3.15rem;
        }

        .home-chart {
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 0.55rem;
        }

        .home-chart__track {
            height: 86px;
            width: 34px;
        }
    }

    body.home-page .container {
        padding-top: 0;
    }

    body.home-page footer.footer {
        display: none;
    }
</style>

@section Scripts {
    <script>
        (() => {
            window.startHomeRecordRefresh = window.startHomeRecordRefresh || (() => {
                let intervalId;
                let lastRenderedSignature = window.sessionStorage.getItem('orbi:home-record-counts:signature') || '';

                async function refreshRecordCounts() {
                    const endpoint = '@Url.Action("RecordCounts", "Home")';
                    const formatter = new Intl.NumberFormat('en-US');
                    const total = document.querySelector('[data-total-records]');
                    const rows = Array.from(document.querySelectorAll('[data-chart-row]'));
                    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

                    if (!total || rows.length === 0) return;

                    function readCount(element) {
                        return Number(element.dataset.currentCount || element.textContent.replace(/,/g, '')) || 0;
                    }

                    function pulse(element) {
                        const target = element.closest('.home-chart__row') || element.closest('.home-total');
                        if (!target) return;

                        target.classList.remove('is-updating');
                        void target.offsetWidth;
                        target.classList.add('is-updating');
                        window.setTimeout(() => target.classList.remove('is-updating'), 520);
                    }

                    function animateCount(element, nextCount) {
                        const previousCount = readCount(element);
                        element.dataset.currentCount = nextCount;

                        if (reduceMotion || previousCount === nextCount) {
                            element.textContent = formatter.format(nextCount);
                            return false;
                        }

                        const duration = 560;
                        const startedAt = performance.now();
                        const easeOut = (value) => 1 - Math.pow(1 - value, 3);

                        function tick(now) {
                            const progress = Math.min((now - startedAt) / duration, 1);
                            const current = Math.round(previousCount + (nextCount - previousCount) * easeOut(progress));
                            element.textContent = formatter.format(current);

                            if (progress < 1) {
                                window.requestAnimationFrame(tick);
                                return;
                            }

                            element.textContent = formatter.format(nextCount);
                        }

                        window.requestAnimationFrame(tick);
                        return true;
                    }

                    try {
                        const response = await fetch(endpoint, {
                            headers: { 'Accept': 'application/json' },
                            cache: 'no-store'
                        });

                        if (!response.ok) return;

                        const data = await response.json();
                        const maxRecords = data.maxRecords || 0;
                        const counts = new Map(data.tableCounts.map(item => [item.tableName, item.count]));
                        const signature = JSON.stringify({
                            totalRecords: data.totalRecords || 0,
                            maxRecords,
                            tableCounts: data.tableCounts.map(item => [item.tableName, item.count])
                        });

                        if (signature === lastRenderedSignature) {
                            return;
                        }

                        lastRenderedSignature = signature;
                        window.sessionStorage.setItem('orbi:home-record-counts:signature', signature);

                        const nextTotal = data.totalRecords || 0;
                        if (animateCount(total, nextTotal)) {
                            pulse(total);
                        }

                        rows.forEach((row) => {
                            const tableName = row.dataset.tableName;
                            const count = counts.get(tableName);
                            if (count === undefined) return;

                            const height = maxRecords === 0 ? 0 : Math.max(8, Math.round(count * 100 / maxRecords));
                            row.style.setProperty('--bar-height', `${height}%`);
                            const countElement = row.querySelector('[data-record-count]');

                            if (countElement) {
                                if (animateCount(countElement, count)) {
                                    pulse(countElement);
                                }
                            }
                        });
                    } catch {
                        // Keep the last rendered values if the refresh fails.
                    }
                }

                return () => {
                    window.clearInterval(intervalId);
                    refreshRecordCounts();
                    intervalId = window.setInterval(refreshRecordCounts, 5000);
                };
            })();

            window.startHomeRecordRefresh();
        })();
    </script>
}
