@{
    ViewData["Title"] = "Not Authorized";
}

<div class="text-center py-5">
    <i class="bi bi-shield-lock-fill" style="font-size: 3rem; color: var(--accent); margin-bottom: 0.5rem;"></i>
    <h1 class="display-5 fw-bold">Not Authorized</h1>
    <p class="lead mb-4">
        You do not have permission to access this page.
    </p>
    <div class="d-flex justify-content-center gap-2 flex-wrap">
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
            <i class="bi bi-house-fill"></i>
            Go Home
        </a>
        <a asp-controller="Account" asp-action="Login" class="btn btn-outline-secondary">
            <i class="bi bi-box-arrow-in-right"></i>
            Sign In
        </a>
    </div>
</div>

