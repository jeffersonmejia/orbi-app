@model StoreViewModel
@{ ViewData["Title"] = "Store Details"; }
<div class="d-flex align-items-center gap-2 mb-3"><i class="bi bi-eye-fill" style="font-size:1.3rem"></i><h3 style="margin:0">Store Details</h3></div><hr />
<div class="card"><div class="card-body">
<dl class="row mb-0">
<dt class="col-sm-3">@Html.DisplayNameFor(m=>m.Name)</dt><dd class="col-sm-9">@Model.Name</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(m=>m.CategoryName)</dt><dd class="col-sm-9">@Model.CategoryName</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(m=>m.Description)</dt><dd class="col-sm-9">@(Model.Description??"N/A")</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(m=>m.Phone)</dt><dd class="col-sm-9">@Model.Phone</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(m=>m.Email)</dt><dd class="col-sm-9">@Model.Email</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(m=>m.Address)</dt><dd class="col-sm-9">@Model.Address</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(m=>m.Latitude)</dt><dd class="col-sm-9">@(Model.Latitude?.ToString("F6")??"N/A")</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(m=>m.Longitude)</dt><dd class="col-sm-9">@(Model.Longitude?.ToString("F6")??"N/A")</dd>
</dl>
</div><div class="card-footer">
<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning"><i class="bi bi-pencil-fill"></i> Edit</a>
<a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Back</a>
</div></div>
